# Shroom — environment variables
#
# Copy this file to `.env` and fill in your values.
# docker-compose.yml reads `.env` automatically.

# ── Required ──────────────────────────────────────────────
# Nigehban's voice. Get a key at https://console.anthropic.com.
# Without this, the world still runs but the journal stays silent.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────
# Hostname for Traefik routing. Only matters if you're using the
# Traefik-based docker-compose.yml. For docker-compose.selfhost.yml,
# leave this unset and access via http://localhost:3000.
# SHROOM_HOST=shroom.example.com

# Which Claude model Nigehban calls. Any valid model ID works.
# NIGEHBAN_MODEL=claude-haiku-4-5

# Real ms per sim tick. Lower = faster world. 3000 (3s) is the default.
# TICK_INTERVAL_MS=3000

# How often Nigehban wakes for a periodic observation. Measured in ticks,
# so at the default 3s tick this is ~30 minutes of real time.
# NIGEHBAN_INTERVAL_TICKS=600

# Hard floor between any two Nigehban API calls. Prevents runaway spend.
# NIGEHBAN_MIN_GAP_TICKS=200

# Max API calls in any rolling 24h window. Set to 0 to silence him entirely.
# NIGEHBAN_DAILY_CAP=48

# Local development only — skips the Docker socket check.
# MOCK=true

# Set to 1 to log raw model responses for debugging.
# NIGEHBAN_DEBUG=1

# Enables /api/dev/* endpoints (speed control, AI toggle, fast-forward).
# Don't enable in a publicly-exposed deployment.
# SHROOM_DEV=true
